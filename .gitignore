# ==============================================================================
# .gitignore — Scalable Log Anomaly Detection Platform
# ==============================================================================

# Python
__pycache__/
*.py[cod]
*.egg-info/
*.egg
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Environment & Secrets
.env
!.env.example

# Testing & Coverage
htmlcov/
.coverage
.coverage.*
.pytest_cache/
test-results.xml
coverage.xml

# Type checking & Linting
.mypy_cache/
.ruff_cache/

# Data files (too large for git)
data/raw/*.csv
data/raw/*.log
data/raw/*.json
data/raw/*.jsonl
data/processed/*.csv

# Model artifacts (too large for git)
models/artifacts/

# Feature store (generated by pipeline)
features/store/
*.npy
*.pkl

# Experiment runs
experiments/runs/
experiments/evaluations/

# Logs
logs/*.log

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Docker
docker-compose.override.yml
