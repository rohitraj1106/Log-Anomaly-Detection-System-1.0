# ==============================================================================
# Log Anomaly Detection Platform — Environment Variables
# ==============================================================================
# Copy this file to .env and modify values as needed.
# All vars use the LADP_ prefix for namespace isolation.
# ==============================================================================

# --- Application ---
LADP_ENV=development                     # development | staging | production
LADP_DEBUG=true                          # Enable debug mode
LADP_LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR | CRITICAL

# --- API Server ---
LADP_API_HOST=0.0.0.0
LADP_API_PORT=8000
LADP_API_WORKERS=1                       # Uvicorn workers (set to CPU count in prod)
LADP_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8501

# --- Security ---
LADP_API_KEY=                            # API key for authentication (leave empty to disable)
LADP_RATE_LIMIT=100/minute               # Rate limit per client IP

# --- Model ---
LADP_MODEL_ARTIFACTS_DIR=models/artifacts
LADP_ACTIVE_MODEL=isolation_forest       # isolation_forest | one_class_svm | autoencoder

# --- Data ---
LADP_RAW_DATA_DIR=data/raw
LADP_PROCESSED_DATA_DIR=data/processed
LADP_LOG_DIR=logs

# --- Monitoring ---
LADP_ENABLE_PROMETHEUS=true
LADP_METRICS_PORT=9090

# --- Dashboard ---
LADP_DASHBOARD_PORT=8501
